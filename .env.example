# --- Supabase (optional) ---
# Create a free project at https://supabase.com, then copy Project URL + anon key.
# If these are empty, the app falls back to the bundled JSON seed data (read-only).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- App config ---
# Email that should get the admin role on first signup. Only this email
# will be able to add/edit questions once logged in.
VITE_ADMIN_EMAIL=you@example.com
